{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "FileStorageDb": "Host=localhost;Port=5432;Database=filestorage_db;Username=postgres;Password=postgres",
    "RabbitMQ": "amqp://guest:guest@localhost:5672"
  },
  "FileStorage": {
    "BasePath": "",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [".jpg", ".png", ".gif", ".pdf", ".csv", ".txt"]
  }
}
