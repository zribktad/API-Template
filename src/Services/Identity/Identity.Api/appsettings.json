{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "IdentityDb": "Host=localhost;Port=5432;Database=identity_db;Username=postgres;Password=postgres",
    "RabbitMQ": "amqp://guest:guest@localhost:5672"
  },
  "Keycloak": {
    "realm": "api-template",
    "auth-server-url": "http://localhost:8080",
    "resource": "api-template-backend",
    "credentials": {
      "secret": "change-me"
    },
    "SkipReadinessCheck": true
  },
  "Bff": {
    "CookieName": ".Identity.Auth",
    "PostLogoutRedirectUri": "/",
    "SessionTimeoutMinutes": 60,
    "TokenRefreshThresholdMinutes": 2
  },
  "BootstrapTenant": {
    "Code": "default",
    "Name": "Default Tenant"
  },
  "Invitation": {
    "InvitationTokenExpiryHours": 72
  }
}
