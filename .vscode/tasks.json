{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: api",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/APITemplate/APITemplate.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test: run all",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/APITemplate.Tests/APITemplate.Tests.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "docker: db up",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "-d",
        "postgres",
        "mongodb"
      ],
      "problemMatcher": []
    },
    {
      "label": "docker: db ensure up",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$pgPortInUse = @(Get-NetTCPConnection -LocalPort 5432 -State Listen -ErrorAction SilentlyContinue).Count -gt 0; $mongoPortInUse = @(Get-NetTCPConnection -LocalPort 27017 -State Listen -ErrorAction SilentlyContinue).Count -gt 0; if ($pgPortInUse) { Write-Host 'Port 5432 is already in use. Skipping postgres startup.' } else { docker compose up -d postgres }; if ($mongoPortInUse) { Write-Host 'Port 27017 is already in use. Skipping mongodb startup.' } else { docker compose up -d mongodb }"
      ],
      "problemMatcher": []
    },
    {
      "label": "docker: db down",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "stop",
        "postgres",
        "mongodb"
      ],
      "problemMatcher": []
    },
    {
      "label": "docker: app up (full)",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "--build",
        "-d"
      ],
      "problemMatcher": []
    },
    {
      "label": "docker: app down (full)",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "down"
      ],
      "problemMatcher": []
    },
    {
      "label": "prepare: debug http",
      "dependsOn": [
        "docker: db ensure up",
        "build: api"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "prepare: debug https",
      "dependsOn": [
        "docker: db ensure up",
        "build: api"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
